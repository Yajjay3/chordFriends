{
  "manifest_version": 3,
  "name": "chordFriends - Daily Chord",
  "version": "1.0.0",
  "description": "Learn a new chord every day! Guitar, piano, ukulele, banjo, and mandolin chord diagrams and staff notation.",
  "permissions": ["storage", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
